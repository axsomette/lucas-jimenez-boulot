---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Lucas Jimenez Boulot — Développeur Full-Stack',
  description = 'Développeur Full-Stack basé à Montpellier. Je conçois et développe des applications web performantes de bout en bout.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Author -->
    <meta name="author" content="Lucas Jimenez Boulot" />

    <!-- Fonts — preconnect + preload pour le LCP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD — Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Lucas Jimenez Boulot",
      "jobTitle": "Développeur Full-Stack",
      "url": String(Astro.site ?? '').replace(/\/$/, ''),
      "email": "lucas@kaneva.io",
      "address": { "@type": "PostalAddress", "addressLocality": "Montpellier", "addressCountry": "FR" },
      "sameAs": [
        "https://github.com/kaneva",
        "https://fr.linkedin.com/in/%F0%9F%92%BB-lucas-jimenez-boulot-35629919b"
      ],
      "knowsAbout": ["Drupal", "PHP", "React", "JavaScript", "Vite", "Node.js", "SQL"]
    })} />

    <!-- JSON-LD — WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Lucas Jimenez Boulot — Portfolio",
      "url": String(Astro.site ?? '').replace(/\/$/, ''),
      "description": description,
      "inLanguage": "fr-FR"
    })} />
  </head>
  <body>
    <Nav />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <script>
      import { initAnimations } from '../scripts/animations';
      document.addEventListener('DOMContentLoaded', initAnimations);
    </script>
  </body>
</html>
