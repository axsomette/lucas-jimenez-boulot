---
/**
 * Projects — Section galerie des projets
 * Suit la convention /new-component (interface Props, HTML sémantique, CSS scoped)
 */
import { getCollection } from 'astro:content';
import ProjectCard from '../ui/ProjectCard.astro';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => {
  // Projets featured en premier, puis par date décroissante
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.date.getTime() - a.data.date.getTime();
});
---

<section id="projets" class="section section--alt" data-section aria-label="Mes projets">
  <div class="container">
    <header class="projects__header reveal">
      <span class="section-label">Réalisations</span>
      <h2 class="section-title">Mes projets</h2>
      <p class="section-subtitle">
        Quelques projets sur lesquels j'ai travaillé — des applications web complètes
        aux outils internes, chaque projet est une occasion d'apprendre.
      </p>
    </header>

    {sortedProjects.length > 0 ? (
      <ul class="projects__grid" aria-label="Liste des projets">
        {sortedProjects.map(project => (
          <li>
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              url={project.data.url}
              github={project.data.github}
              featured={project.data.featured}
              image={project.data.image}
            />
          </li>
        ))}
      </ul>
    ) : (
      <p class="projects__empty" role="status">
        Des projets arrivent bientôt…
      </p>
    )}

    <div class="projects__cta">
      <a
        href="https://github.com/axsomette"
        class="btn btn--outline"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Voir tous mes projets sur GitHub (ouvre dans un nouvel onglet)"
      >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
        </svg>
        Voir tous mes projets sur GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .projects__header {
    max-width: 640px;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .projects__empty {
    font-size: var(--text-lg);
    color: var(--color-text-3);
    text-align: center;
    padding: var(--space-16) 0;
  }

  .projects__cta {
    display: flex;
    justify-content: center;
  }
</style>
