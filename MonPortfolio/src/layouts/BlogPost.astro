---
/**
 * BlogPost.astro — Layout pour les articles de blog
 * Breadcrumb, méta OG, JSON-LD BlogPosting, bio auteur
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title:       string;
  date:        Date;
  excerpt:     string;
  tags:        string[];
  readingTime: number;
  ogImage?:    string;
}

const { title, date, excerpt, tags, readingTime, ogImage } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('fr-FR', {
  year:  'numeric',
  month: 'long',
  day:   'numeric',
}).format(new Date(date));

const isoDate = new Date(date).toISOString();
const base    = import.meta.env.BASE_URL.replace(/\/$/, '');

const jsonLd = {
  '@context':        'https://schema.org',
  '@type':           'BlogPosting',
  headline:          title,
  description:       excerpt,
  datePublished:     isoDate,
  inLanguage:        'fr-FR',
  author: {
    '@type': 'Person',
    name:    'Lucas Jimenez Boulot',
    url:     String(Astro.site ?? '').replace(/\/$/, ''),
  },
  publisher: {
    '@type': 'Person',
    name:    'Lucas Jimenez Boulot',
  },
};
---

<BaseLayout
  title={`${title} · Lucas Jimenez Boulot`}
  description={excerpt}
  ogImage={ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <article class="blog-post">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href={`${base}/`} class="breadcrumb__link">Accueil</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href={`${base}/blog`} class="breadcrumb__link">Blog</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span class="breadcrumb__current" aria-current="page">{title}</span>
      </nav>

      <!-- En-tête de l'article -->
      <header class="post__header">
        <div class="post__meta">
          <time class="post__date" datetime={isoDate}>{formattedDate}</time>
          <span class="post__sep" aria-hidden="true">·</span>
          <span class="post__reading-time">{readingTime} min de lecture</span>
        </div>

        <h1 class="post__title">{title}</h1>
        <p class="post__excerpt">{excerpt}</p>

        {tags.length > 0 && (
          <ul class="post__tags" aria-label="Tags de l'article">
            {tags.map(tag => (
              <li><span class="tag">{tag}</span></li>
            ))}
          </ul>
        )}
      </header>

      <!-- Contenu de l'article -->
      <div class="post__content prose">
        <slot />
      </div>

      <!-- Pied de l'article -->
      <footer class="post__footer">

        <div class="post__author card">
          <img
            src={`${base}/profile.jpeg`}
            alt="Lucas Jimenez Boulot"
            class="post__author-avatar"
            width="52"
            height="52"
            loading="lazy"
          />
          <div class="post__author-info">
            <p class="post__author-name">Lucas Jimenez Boulot</p>
            <p class="post__author-role">Développeur Full-Stack · Montpellier</p>
            <p class="post__author-bio">
              Je conçois et développe des applications web : Drupal, PHP, React, JS.
              Ce blog documente mes retours d'expérience.
            </p>
          </div>
        </div>

        <a href={`${base}/blog`} class="btn btn--outline post__back" aria-label="Retour à la liste des articles">
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Retour au blog
        </a>

      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-block: var(--space-section);
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }

  .breadcrumb__link {
    color: var(--color-text-2);
    transition: color var(--transition-fast);
  }

  .breadcrumb__link:hover {
    color: var(--color-accent-text);
  }

  .breadcrumb__sep {
    color: var(--color-text-3);
  }

  .breadcrumb__current {
    color: var(--color-text-2);
    /* Tronque les titres longs sur mobile */
    max-width: 40ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── En-tête de l'article ── */
  .post__header {
    max-width: 720px;
    margin-bottom: var(--space-12);
  }

  .post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .post__date,
  .post__reading-time,
  .post__sep {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-3);
  }

  .post__title {
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-5);
  }

  .post__excerpt {
    font-size: var(--text-lg);
    color: var(--color-text-2);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ── Contenu prose ── */
  .prose {
    max-width: 720px;
    margin-bottom: var(--space-16);
  }

  .prose :global(h2) {
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    margin-top: var(--space-12);
    margin-bottom: var(--space-5);
  }

  .prose :global(h3) {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: var(--leading-snug);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .prose :global(p) {
    font-size: var(--text-base);
    color: #c0c0c0;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }

  .prose :global(a) {
    color: var(--color-accent-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .prose :global(a:hover) {
    color: var(--color-text);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(li) {
    font-size: var(--text-base);
    color: #c0c0c0;
    line-height: var(--leading-relaxed);
  }

  .prose :global(li strong) {
    color: var(--color-text);
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    overflow-x: auto;
    margin-bottom: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: #e2e8f0;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    color: var(--color-accent-text);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-5);
    margin: var(--space-6) 0;
    color: var(--color-text-2);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-10) 0;
  }

  /* ── Pied de l'article ── */
  .post__footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: 720px;
  }

  .post__author {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-6);
  }

  .post__author-avatar {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-full);
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    border: 2px solid var(--color-border);
  }

  .post__author-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .post__author-name {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: 1.2;
  }

  .post__author-role {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: 1.3;
  }

  .post__author-bio {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-2);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .post__title {
      font-size: var(--text-3xl);
    }

    .post__author {
      flex-direction: column;
    }

    .breadcrumb__current {
      max-width: 20ch;
    }
  }
</style>
