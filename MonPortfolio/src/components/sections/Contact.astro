---
/**
 * Contact.astro — Section contact améliorée
 * Formspree : https://formspree.io/f/mrejobke
 * Turnstile  : 0x4AAAAAADML4xDhDRFZnWrK
 *
 * Améliorations UX/a11y :
 * - Copy humain et actionnable (ux-copy skill)
 * - Success state complet avec gestion du focus (accessibility-review)
 * - Validation par champ avec aria-invalid + aria-describedby (a11y)
 * - Grid stretch pour équilibrer les deux cartes (design-critique)
 * - Section-label non dupliqué dans la card formulaire (design-critique)
 */

const FORMSPREE_ENDPOINT = import.meta.env.PUBLIC_FORMSPREE_ID
  ? `https://formspree.io/f/${import.meta.env.PUBLIC_FORMSPREE_ID}`
  : 'https://formspree.io/f/mrejobke';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY
  ?? '0x4AAAAAADML4xDhDRFZnWrK';

const projectTypes = [
  { label: 'Créer un site web de A à Z',       icon: '🌐' },
  { label: 'Refaire un site qui vieillit mal',  icon: '✦'  },
  { label: 'Rendre un site plus rapide',        icon: '⚡'  },
  { label: 'Ajouter des fonctionnalités',       icon: '+'  },
  { label: 'Connecter deux outils ensemble',    icon: '⟷'  },
  { label: 'Juste poser une question',          icon: '?'  },
];

---

<!-- Turnstile chargé en lazy via JS (voir <script> en bas) -->

<section id="contact" class="section section--alt" data-section aria-label="Contact">
  <div class="container">

    <header class="contact__header reveal">
      <span class="section-label">Contact</span>
      <h2 class="section-title">Vous avez un projet&nbsp;?</h2>
      <p class="section-subtitle">
        Refonte, nouvelle application ou simple question technique :
        deux façons de me joindre, même délai de réponse.
      </p>
    </header>

    <div class="contact__main reveal">

      {/* ══ Formulaire ══ */}
      <div class="contact__form-card card" id="form-card">

        {/* En-tête de la card */}
        <div class="contact__form-top">
          <h3 class="contact__form-title">Écrivez-moi directement</h3>
          <p class="contact__form-meta">
            <span class="status-dot" aria-hidden="true"></span>
            Répond sous 48&nbsp;h
          </p>
        </div>

        {/* Formulaire */}
        <form
          id="contact-form"
          class="contact__form"
          novalidate
          data-endpoint={FORMSPREE_ENDPOINT}
          aria-label="Formulaire de contact"
        >
          {/* Nom + Email côte à côte */}
          <div class="form__row">
            <div class="form__group">
              <label class="form__label" for="contact-nom">Nom</label>
              <input
                class="form__input"
                type="text"
                id="contact-nom"
                name="nom"
                placeholder="Jean Dupont"
                required
                autocomplete="name"
                aria-required="true"
                aria-describedby="error-nom"
              />
              <span id="error-nom" class="form__error" role="alert" hidden>
                Ce champ est requis.
              </span>
            </div>

            <div class="form__group">
              <label class="form__label" for="contact-email">Email</label>
              <input
                class="form__input"
                type="email"
                id="contact-email"
                name="email"
                placeholder="jean@exemple.fr"
                required
                autocomplete="email"
                aria-required="true"
                aria-describedby="error-email"
              />
              <span id="error-email" class="form__error" role="alert" hidden>
                Adresse email invalide.
              </span>
            </div>
          </div>

          {/* Sujet — champ texte libre */}
          <div class="form__group">
            <label class="form__label" for="contact-sujet">
              Sujet
              <span class="form__optional" aria-label="optionnel">(optionnel)</span>
            </label>
            <input
              class="form__input"
              type="text"
              id="contact-sujet"
              name="sujet"
              placeholder="Ex : refonte site, question Drupal, mission…"
              autocomplete="off"
            />
          </div>

          {/* Message */}
          <div class="form__group">
            <label class="form__label" for="contact-message">Message</label>
            <textarea
              class="form__textarea"
              id="contact-message"
              name="message"
              rows="4"
              placeholder="Parlez-moi de votre projet, besoin ou question…"
              required
              aria-required="true"
              aria-describedby="error-message"
            ></textarea>
            <span id="error-message" class="form__error" role="alert" hidden>
              Ce champ est requis.
            </span>
          </div>

          {/* Turnstile — rendu en mode explicit après chargement lazy */}
          <div id="turnstile-container" aria-label="Vérification de sécurité"></div>
          <span
            id="error-turnstile"
            class="form__error"
            role="alert"
            hidden
          >
            Confirmez d'abord la vérification de sécurité ci-dessus.
          </span>

          {/* Submit */}
          <button
            type="submit"
            class="btn btn--primary form__submit"
            id="form-submit"
          >
            <svg
              class="form__submit-icon"
              aria-hidden="true"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            Envoyer mon message
          </button>

          {/* Erreur globale réseau */}
          <p
            id="form-global-error"
            class="form__global-error"
            role="alert"
            hidden
          ></p>

          {/* ── Honeypot anti-spam (couche 1 : champ piège) ── */}
          <div class="form__honeypot" aria-hidden="true">
            <label for="hp-website">Ne pas remplir</label>
            <input
              type="text"
              id="hp-website"
              name="_gotcha"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          {/* Couche 2 : jeton JS (prouve que JS tourne, les bots simples ne l'injectent pas) */}
          <input type="hidden" name="_js_token" value="" />
        </form>

        {/* State succès — remplace le formulaire */}
        <div
          class="form__success"
          id="form-success"
          role="status"
          aria-live="polite"
          hidden
        >
          <div class="form__success-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h4 class="form__success-title" tabindex="-1" id="form-success-heading">
            Message reçu&nbsp;!
          </h4>
          <p class="form__success-body" id="form-success-body">
            Je vous reviens sous 48&nbsp;h.
          </p>
          <button
            type="button"
            class="btn btn--ghost form__success-reset"
            id="form-reset"
            aria-label="Envoyer un autre message"
          >
            Envoyer un autre message
          </button>
        </div>

      </div>

      {/* ══ Ligne LinkedIn — alternative secondaire ══ */}
      <div class="contact__li-row">

        {/* Séparateur textuel */}
        <span class="contact__li-or" aria-hidden="true">ou</span>

        {/* Profil */}
        <div class="contact__li-profile">
          <div class="contact__li-avatar" aria-hidden="true">
            <img
              src={`${import.meta.env.BASE_URL}/profile.jpeg`}
              alt=""
              width="36"
              height="36"
              loading="lazy"
              onerror="this.style.visibility='hidden'"
            />
            <span class="contact__li-initials">LJB</span>
          </div>
          <div class="contact__li-info">
            <span class="contact__li-name">Lucas Jimenez Boulot</span>
            <span class="contact__li-role">
              <svg class="contact__li-logo" viewBox="0 0 24 24" aria-hidden="true">
                <rect width="24" height="24" rx="4" fill="#0A66C2"/>
                <path d="M6.94 5.5A1.44 1.44 0 1 1 5.5 6.94 1.44 1.44 0 0 1 6.94 5.5ZM5.5 9.5H8.38V18H5.5ZM10.5 9.5h2.76v1.17h.04A3 3 0 0 1 16 9.25c2.9 0 3.44 1.9 3.44 4.37V18H16.6v-3.78c0-1 0-2.3-1.4-2.3s-1.62 1.08-1.62 2.23V18H10.5Z" fill="white"/>
              </svg>
              Développeur Full-Stack · Montpellier
            </span>
          </div>
        </div>

        {/* CTA */}
        <a
          href="https://fr.linkedin.com/in/%F0%9F%92%BB-lucas-jimenez-boulot-35629919b"
          class="btn btn--outline contact__li-cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Envoyer un message sur LinkedIn (ouvre un nouvel onglet)"
        >
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          LinkedIn
        </a>

      </div>

    </div>

    {/* Types de projets */}
    <div class="contact__types reveal" aria-label="Types de projets">
      <p class="contact__types-label">Je peux vous aider sur&nbsp;:</p>
      <ul class="contact__types-list">
        {projectTypes.map(p => (
          <li class="contact__type-chip">
            <span aria-hidden="true">{p.icon}</span>
            {p.label}
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  /* ── Section header — aligné avec la zone de contact ── */
  .contact__header {
    max-width: 720px;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .contact__header strong {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }

  /* [hidden] doit toujours l'emporter sur les display: flex/block des composants */
  [hidden] { display: none !important; }

  /* ── Layout empilé : formulaire haut, LinkedIn bas — centré et contenu ── */
  .contact__main {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
    max-width: 720px;
    margin-inline: auto;
  }

  /* ══ Card formulaire ══ */
  .contact__form-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  /* Ligne accent indigo en haut */
  .contact__form-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
    pointer-events: none;
  }

  /* En-tête card (titre + dot statut) */
  .contact__form-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .contact__form-title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: var(--leading-tight);
  }

  .contact__form-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-3);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Champs ── */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex: 1;
  }

  /* Ligne Nom + Email côte à côte */
  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form__label {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-2);
  }

  .form__optional {
    font-weight: var(--font-weight-normal);
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-text-3);
    font-size: 0.85em;
  }

  /* Inputs / select / textarea */
  .form__input,
  .form__select,
  .form__textarea {
    width: 100%;
    padding: 0.625rem var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
    min-height: 44px; /* WCAG 2.5.5 touch target */
  }

  .form__input::placeholder,
  .form__textarea::placeholder { color: var(--color-text-3); }

  .form__input:hover,
  .form__select:hover,
  .form__textarea:hover { border-color: var(--color-border-hover); }

  .form__input:focus-visible,
  .form__select:focus-visible,
  .form__textarea:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }

  /* État invalide — WCAG 3.3.1 */
  .form__input[aria-invalid="true"],
  .form__textarea[aria-invalid="true"] {
    border-color: #f87171;
    box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.12);
  }

  /* Textarea */
  .form__textarea {
    resize: vertical;
    min-height: 110px;
    line-height: var(--leading-relaxed);
  }

  /* Erreurs par champ — WCAG 3.3.1 */
  .form__error {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: #f87171;
    line-height: var(--leading-normal);
  }

  /* Erreur globale réseau */
  .form__global-error {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: #f87171;
    line-height: var(--leading-normal);
    margin-top: var(--space-1);
  }

  /* Turnstile */
  .cf-turnstile { margin-top: var(--space-2); }

  /* Bouton submit */
  .form__submit {
    width: 100%;
    justify-content: center;
    margin-top: var(--space-2);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .form__submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }

  .form__submit-icon { flex-shrink: 0; }

  /* ── State succès ── */
  .form__success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-4);
    flex: 1;
    padding: var(--space-8) var(--space-4);
    animation: fadeIn 300ms var(--ease-out);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .form__success-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #22c55e;
  }

  .form__success-title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: var(--leading-tight);
  }

  .form__success-body {
    font-size: var(--text-base);
    color: var(--color-text-2);
    line-height: var(--leading-relaxed);
    max-width: 28ch;
  }

  .form__success-reset {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }

  /* ══ Row LinkedIn — présence affirmée mais secondaire ══ */
  .contact__li-row {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-hover);
    background: var(--color-surface);
    transition: border-color var(--transition-fast);
  }

  .contact__li-row:hover {
    border-color: rgba(10, 102, 194, 0.4);
  }

  /* "ou" — séparateur */
  .contact__li-or {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    flex-shrink: 0;
    padding-right: var(--space-4);
    border-right: 1px solid var(--color-border);
  }

  /* Profil : avatar + nom + rôle */
  .contact__li-profile {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .contact__li-avatar {
    position: relative;
    width: 44px; height: 44px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: var(--color-surface-2);
    border: 2px solid var(--color-border);
  }

  .contact__li-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    position: relative; z-index: 1;
  }

  .contact__li-initials {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-2);
    z-index: 0;
  }

  .contact__li-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .contact__li-name {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact__li-role {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact__li-logo {
    width: 13px; height: 13px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Bouton LinkedIn */
  .contact__li-cta {
    flex-shrink: 0;
  }

  /* ── Types de projets — aligné avec la zone de contact ── */
  .contact__types {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 720px;
    margin-inline: auto;
  }

  .contact__types-label {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .contact__types-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .contact__type-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: #c0c0c0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: border-color var(--transition-fast), color var(--transition-fast);
    cursor: default;
  }

  .contact__type-chip:hover {
    border-color: var(--color-border-accent);
    color: var(--color-text);
  }

  /* ── Honeypot — invisible aux humains ── */
  .form__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    tab-size: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .form__row { grid-template-columns: 1fr; }

    .contact__li-or { display: none; }
    .contact__li-row { gap: var(--space-3); }
  }

  @media (max-width: 400px) {
    .contact__form-card { padding: var(--space-5); }
    .contact__li-row { flex-wrap: wrap; }
    .contact__li-cta { width: 100%; justify-content: center; }
  }
</style>

<script>
  // ── Initialisation (IIFE pour éviter le return au niveau module) ──
  (function initContactForm() {
  const form        = document.getElementById('contact-form')         as HTMLFormElement    | null;
  const submitBtn   = document.getElementById('form-submit')          as HTMLButtonElement  | null;
  const globalError = document.getElementById('form-global-error')    as HTMLElement        | null;
  const successEl   = document.getElementById('form-success')         as HTMLElement        | null;
  const successHead = document.getElementById('form-success-heading') as HTMLElement        | null;
  const successBody = document.getElementById('form-success-body')    as HTMLElement        | null;
  const resetBtn    = document.getElementById('form-reset')           as HTMLButtonElement  | null;

  if (!form || !submitBtn) return;

  const endpoint = form.dataset.endpoint ?? '';

  // ── Anti-spam : couche 2 — jeton JS injecté au runtime ──────────
  // Un bot simple qui parse le HTML ne verra jamais cette valeur injectée dynamiquement
  const jsTokenField = form.querySelector<HTMLInputElement>('[name="_js_token"]');
  if (jsTokenField) jsTokenField.value = 'human_' + Math.random().toString(36).slice(2, 9);

  // ── Anti-spam : couche 3 — horodatage de chargement du form ─────
  // Rejet si le formulaire est soumis en moins de 2,5 s (impossible pour un humain)
  const formLoadTime = Date.now();

  // ── Helpers ───────────────────────────────────────────────────

  /** Marque un champ invalide avec ARIA */
  function setFieldError(id: string, errorId: string, message: string, invalid: boolean) {
    const field = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    const err   = document.getElementById(errorId) as HTMLElement | null;
    if (!field || !err) return;

    field.setAttribute('aria-invalid', invalid ? 'true' : 'false');
    if (invalid) {
      err.textContent = message;
      err.hidden = false;
    } else {
      err.hidden = true;
    }
  }

  function clearAllErrors() {
    setFieldError('contact-nom',     'error-nom',     '',  false);
    setFieldError('contact-email',   'error-email',   '',  false);
    setFieldError('contact-message', 'error-message', '',  false);
    const tsErr = document.getElementById('error-turnstile');
    if (tsErr) tsErr.hidden = true;
    if (globalError) { globalError.hidden = true; globalError.textContent = ''; }
  }

  function setLoading(on: boolean) {
    submitBtn!.disabled = on;
    submitBtn!.innerHTML = on
      ? `<svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
           <circle cx="12" cy="12" r="10" opacity=".25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
         </svg> Envoi en cours…`
      : `<svg class="form__submit-icon" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
           <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
         </svg> Envoyer mon message`;
  }

  function showSuccess(email: string) {
    // Remplacer le formulaire par le state succès
    form!.hidden = true;
    if (successEl)  successEl.hidden  = false;
    // Personnaliser le message avec l'email saisi
    if (successBody && email) {
      successBody.textContent = `Je vous reviens sous 48 h à ${email}.`;
    }
    // Gestion du focus — WCAG 2.4.3
    successHead?.focus();
  }

  function resetToForm() {
    if (successEl) successEl.hidden = true;
    form!.hidden = false;
    form!.reset();
    clearAllErrors();
    // Reset Turnstile si dispo
    const w = window as Window & { turnstile?: { reset: () => void } };
    w.turnstile?.reset();
    // Focus sur le premier champ
    (document.getElementById('contact-nom') as HTMLInputElement)?.focus();
  }

  // ── Validation à la perte de focus (blur) — UX proactive ──────

  ['contact-nom', 'contact-message'].forEach(id => {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    el?.addEventListener('blur', () => {
      if (!el.value.trim()) {
        setFieldError(id, `error-${id.replace('contact-', '')}`, 'Ce champ est requis.', true);
      } else {
        setFieldError(id, `error-${id.replace('contact-', '')}`, '', false);
      }
    });
  });

  const emailEl = document.getElementById('contact-email') as HTMLInputElement | null;
  emailEl?.addEventListener('blur', () => {
    const v = emailEl.value.trim();
    if (!v) {
      setFieldError('contact-email', 'error-email', 'Ce champ est requis.', true);
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) {
      setFieldError('contact-email', 'error-email', 'Adresse email invalide.', true);
    } else {
      setFieldError('contact-email', 'error-email', '', false);
    }
  });

  // ── Soumission ────────────────────────────────────────────────

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    clearAllErrors();

    const nom     = (form.querySelector('#contact-nom')     as HTMLInputElement)?.value.trim();
    const email   = (form.querySelector('#contact-email')   as HTMLInputElement)?.value.trim();
    const message = (form.querySelector('#contact-message') as HTMLTextAreaElement)?.value.trim();

    // ── Anti-spam : vérifications honeypot ──────────────────────────
    const honeypot = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
    const jsToken  = form.querySelector<HTMLInputElement>('[name="_js_token"]');
    const elapsed  = Date.now() - formLoadTime;

    const isBot =
      (honeypot?.value && honeypot.value.length > 0) || // couche 1 : champ piège rempli
      !jsToken?.value.startsWith('human_')            || // couche 2 : jeton JS absent/invalide
      elapsed < 2500;                                    // couche 3 : soumis < 2,5 s

    if (isBot) {
      // Fausse réussite — le bot croit avoir réussi, on ne lui indique rien
      showSuccess(email ?? '');
      return;
    }
    // ────────────────────────────────────────────────────────────────

    // Validation complète
    let hasError = false;

    if (!nom) {
      setFieldError('contact-nom', 'error-nom', 'Ce champ est requis.', true);
      hasError = true;
    }
    if (!email) {
      setFieldError('contact-email', 'error-email', 'Ce champ est requis.', true);
      hasError = true;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setFieldError('contact-email', 'error-email', 'Adresse email invalide.', true);
      hasError = true;
    }
    if (!message) {
      setFieldError('contact-message', 'error-message', 'Ce champ est requis.', true);
      hasError = true;
    }

    // Validation Turnstile
    const tsToken = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
    if (!tsToken?.value) {
      const tsErr = document.getElementById('error-turnstile');
      if (tsErr) tsErr.hidden = false;
      hasError = true;
    }

    if (hasError) {
      // Focus sur le premier champ en erreur
      const firstInvalid = form.querySelector('[aria-invalid="true"]') as HTMLElement | null;
      firstInvalid?.focus();
      return;
    }

    setLoading(true);

    try {
      const formData = new FormData(form);
      const payload: Record<string, string> = {};
      formData.forEach((v, k) => { if (typeof v === 'string') payload[k] = v; });

      const res = await fetch(endpoint, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify(payload),
      });

      if (res.ok) {
        showSuccess(email);
      } else {
        const data = await res.json().catch(() => ({}));
        const msg  = (data as { error?: string }).error ?? 'Une erreur est survenue.';
        if (globalError) { globalError.textContent = msg; globalError.hidden = false; }
      }
    } catch {
      if (globalError) {
        globalError.textContent = 'Envoi échoué. Réessayez ou écrivez-moi sur LinkedIn.';
        globalError.hidden = false;
      }
    } finally {
      setLoading(false);
    }
  });

  // ── Bouton "Envoyer un autre message" ─────────────────────────
  resetBtn?.addEventListener('click', resetToForm);

  })(); // fin IIFE initContactForm

  // ══════════════════════════════════════════════════════════════════
  // Turnstile — chargement LAZY via IntersectionObserver
  // Ne se charge QUE quand l'utilisateur approche la section Contact
  // (évite de bloquer le chargement de la page entière au démarrage)
  // ══════════════════════════════════════════════════════════════════
  (function initTurnstileLazy() {
    const SITE_KEY   = '0x4AAAAAADML4xDhDRFZnWrK';
    const container  = document.getElementById('turnstile-container');
    const section    = document.getElementById('contact');
    if (!container || !section) return;

    let loaded = false;

    const loadTurnstile = () => {
      if (loaded) return;
      loaded = true;

      const script = document.createElement('script');
      // Mode explicit : Turnstile n'initialise rien automatiquement
      script.src   = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=onTurnstileLoad';
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    };

    // Callback global appelé par Turnstile une fois son script chargé
    (window as any).onTurnstileLoad = () => {
      (window as any).turnstile?.render(container, {
        sitekey:  SITE_KEY,
        theme:    'dark',
        size:     'flexible',
      });
    };

    // Observer : déclenche le chargement 300px avant que la section soit visible
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          obs.disconnect();
          loadTurnstile();
        }
      },
      { rootMargin: '300px' }
    );

    obs.observe(section);
  })();
</script>
