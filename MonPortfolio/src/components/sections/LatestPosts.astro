---
/**
 * LatestPosts.astro — Section home : 3 derniers articles
 * Design aligné sur Projects.astro (grille de cards)
 */
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map(post => {
    const wordCount   = post.body.split(/\s+/).length;
    const readingTime = Math.max(1, Math.ceil(wordCount / 200));
    return { ...post, readingTime };
  });

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

{latestPosts.length > 0 && (
  <section class="section" aria-label="Derniers articles">
    <div class="container">

      <header class="latest-posts__header reveal">
        <span class="section-label">Blog</span>
        <h2 class="section-title">Derniers articles</h2>
        <p class="section-subtitle">
          Retours d'expérience sur Drupal, PHP, JavaScript et le développement web.
        </p>
      </header>

      <ul class="latest-posts__grid reveal" aria-label="Articles récents">
        {latestPosts.map(post => {
          const formattedDate = new Intl.DateTimeFormat('fr-FR', {
            year:  'numeric',
            month: 'long',
            day:   'numeric',
          }).format(new Date(post.data.date));

          return (
            <li>
              <a
                href={`${base}/blog/${post.slug}`}
                class="post-card card"
                aria-label={`Lire l'article : ${post.data.title}`}
              >
                <article>
                  <header class="post-card__header">
                    <div class="post-card__meta">
                      <time
                        class="post-card__date"
                        datetime={new Date(post.data.date).toISOString()}
                      >
                        {formattedDate}
                      </time>
                      <span class="post-card__sep" aria-hidden="true">·</span>
                      <span class="post-card__reading-time">
                        {post.readingTime} min
                      </span>
                    </div>
                    <h3 class="post-card__title">{post.data.title}</h3>
                  </header>

                  <p class="post-card__excerpt">{post.data.excerpt}</p>

                  {post.data.tags.length > 0 && (
                    <footer class="post-card__tags" aria-label="Tags">
                      {post.data.tags.slice(0, 3).map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </footer>
                  )}
                </article>
              </a>
            </li>
          );
        })}
      </ul>

      <div class="latest-posts__cta reveal">
        <a href={`${base}/blog`} class="btn btn--outline">
          Voir tous les articles
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

    </div>
  </section>
)}

<style>
  .latest-posts__header {
    max-width: 860px;
  }

  /* ── Grille de 3 cards ── */
  .latest-posts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  /* ── Card ── */
  .post-card {
    display: block;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-base), transform var(--transition-slow);
  }

  .post-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .post-card article {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
  }

  .post-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .post-card__date,
  .post-card__reading-time,
  .post-card__sep {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-3);
  }

  .post-card__title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-card__title {
    color: var(--color-accent-text);
  }

  .post-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }

  /* ── CTA "Voir tout" ── */
  .latest-posts__cta {
    display: flex;
    justify-content: flex-start;
  }
</style>
