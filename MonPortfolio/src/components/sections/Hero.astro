---
---

<section id="hero" class="hero section" data-section aria-label="Introduction">
  <div class="container hero__inner">

    <div class="hero__content reveal">
      <div class="hero__location" aria-label="Localisation">
        <svg aria-hidden="true" width="12" height="12" viewBox="0 0 16 16" fill="none">
          <path d="M8 1.5A4.5 4.5 0 0 0 3.5 6c0 3 4.5 8.5 4.5 8.5S12.5 9 12.5 6A4.5 4.5 0 0 0 8 1.5Zm0 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" fill="currentColor"/>
        </svg>
        <span class="hero__location-text">Montpellier, FR</span>
      </div>

      <h1 class="hero__title">
        Du code propre.<br />
        Des produits<br />
        <em class="hero__title-em">qui marchent.</em>
      </h1>

      <p class="hero__desc">
        Je suis <strong>Lucas Jimenez Boulot</strong>, développeur Full-Stack.
        Je conçois et développe des applications web de bout en bout —
        du backend robuste à l'interface soignée.
      </p>

      <div class="hero__actions">
        <a href="#projets" class="btn btn--primary">
          Voir mes projets
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 3l5 5-5 5M3 8h10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
<a href="https://fr.linkedin.com/in/%F0%9F%92%BB-lucas-jimenez-boulot-35629919b" class="btn btn--ghost" target="_blank" rel="noopener noreferrer" aria-label="Mon profil LinkedIn (ouvre dans un nouvel onglet)">
          LinkedIn
          <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M3.5 3H9m0 0v5.5M9 3 3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <aside class="hero__aside reveal" aria-label="Stack technique">
      <div class="hero__terminal" aria-hidden="true">
        <div class="hero__terminal-bar">
          <div class="hero__terminal-dots">
            <span></span><span></span><span></span>
          </div>
          <span class="hero__terminal-file">lucas.config.ts</span>
        </div>
        <pre class="hero__code"><code
><span class="t-kw">const</span> <span class="t-id">dev</span> <span class="t-op">=</span> <span class="t-p">{'{' }</span>
  <span class="t-key">name</span><span class="t-p">:</span>     <span class="t-str">'Lucas Jimenez Boulot'</span><span class="t-p">,</span>
  <span class="t-key">role</span><span class="t-p">:</span>     <span class="t-str">'Full-Stack Developer'</span><span class="t-p">,</span>
  <span class="t-key">location</span><span class="t-p">:</span> <span class="t-str">'Montpellier, FR'</span><span class="t-p">,</span>
  <span class="t-key">stack</span><span class="t-p">:</span>    <span class="t-p">[</span>
    <span class="t-str">'Drupal'</span><span class="t-p">,</span>  <span class="t-str">'PHP'</span><span class="t-p">,</span>
    <span class="t-str">'React'</span><span class="t-p">,</span>   <span class="t-str">'JS / Vite'</span><span class="t-p">,</span>
    <span class="t-str">'Node.js'</span><span class="t-p">,</span> <span class="t-str">'SQL'</span><span class="t-p">,</span>
  <span class="t-p">],</span>
<span class="t-p">{'}'}</span><span class="t-p">;</span>
</code></pre>
      </div>

      <dl class="hero__meta">
        <div class="hero__meta-item">
          <dt class="hero__meta-label">Spécialité</dt>
          <dd class="hero__meta-value">Full-Stack · Web</dd>
        </div>
        <div class="hero__meta-item">
          <dt class="hero__meta-label">Localisation</dt>
          <dd class="hero__meta-value">Montpellier, FR</dd>
        </div>
        <div class="hero__meta-item">
          <dt class="hero__meta-label">Projets</dt>
          <dd class="hero__meta-value">Perso &amp; Pro</dd>
        </div>
      </dl>
    </aside>

  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    padding-block-start: calc(var(--nav-height) + var(--space-section));
    min-height: 100dvh;
    display: flex;
    align-items: center;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--space-16);
    align-items: start;
  }

  /* ── Localisation ── */
  .hero__location {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    color: var(--color-text-3);
  }

  .hero__location svg {
    flex-shrink: 0;
  }

  .hero__location-text {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-2);
  }

  /* ── Titre ── */
  .hero__title {
    font-size: var(--text-hero);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .hero__title-em {
    font-style: normal;
    color: var(--color-accent);
  }

  /* ── Description ── */
  .hero__desc {
    font-size: var(--text-lg);
    color: var(--color-text-2);
    max-width: 48ch;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  /* ── Actions ── */
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ── Aside ── */
  .hero__aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-block-start: var(--space-4);
  }

  /* Terminal */
  .hero__terminal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero__terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-2);
  }

  .hero__terminal-dots {
    display: flex;
    gap: 5px;
  }

  .hero__terminal-dots span {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-border-hover);
  }

  .hero__terminal-file {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-2);
  }

  .hero__code {
    padding: var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.85;
    white-space: pre;
    overflow-x: auto;
    margin: 0;
    color: var(--color-text-2);
  }

  /* Syntax */
  .t-kw  { color: #c792ea; }
  .t-id  { color: #82aaff; }
  .t-str { color: #c3e88d; }
  .t-key { color: #f07178; }
  .t-op  { color: var(--color-text-2); }
  .t-p   { color: var(--color-text-3); }

  /* Meta */
  .hero__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero__meta-item {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .hero__meta-item + .hero__meta-item {
    border-left: 1px solid var(--color-border);
  }

  .hero__meta-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .hero__meta-value {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
  }

  .hero__meta-value--green {
    color: #4ade80;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, var(--color-border-hover), transparent);
    margin: auto;
    animation: scroll-reveal 2.5s ease-in-out infinite;
  }

  @keyframes scroll-reveal {
    0%, 100% { opacity: 0; transform: scaleY(0.4) translateY(-30%); }
    50%       { opacity: 0.6; transform: scaleY(1) translateY(0); }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .hero__title { font-size: var(--text-5xl); }
    .hero__aside { padding-block-start: 0; }
    .hero__meta  { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 480px) {
    .hero__title { font-size: var(--text-4xl); }
    .hero__meta  { grid-template-columns: 1fr; }
    .hero__meta-item + .hero__meta-item {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }
  }
</style>
