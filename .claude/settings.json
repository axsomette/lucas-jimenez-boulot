{
  "model": "claude-sonnet-4-5",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx astro *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
