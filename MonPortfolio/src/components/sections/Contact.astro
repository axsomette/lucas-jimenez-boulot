---
const projectTypes = [
  { label: 'Créer un site web de A à Z',           icon: '🌐' },
  { label: 'Refaire un site qui vieillit mal',      icon: '✦' },
  { label: 'Rendre un site plus rapide',            icon: '⚡' },
  { label: 'Ajouter des fonctionnalités',           icon: '+' },
  { label: 'Connecter deux outils ensemble',        icon: '⟷' },
  { label: 'Juste poser une question',              icon: '?' },
];
---

<section id="contact" class="section section--alt" data-section aria-label="Contact">
  <div class="container">

    <header class="contact__header reveal">
      <span class="section-label">Contact</span>
      <h2 class="section-title">Vous avez un projet&nbsp;?</h2>
      <p class="section-subtitle">
        Que ce soit une refonte, une nouvelle application ou simplement une question technique —
        je suis le bon interlocuteur. La meilleure façon de me joindre : <strong>LinkedIn</strong>.
      </p>
    </header>

    <div class="contact__main reveal">

      {/* ── Card LinkedIn ── */}
      <div class="contact__li-card card">

        <div class="contact__li-header">
          <svg class="contact__li-logo" viewBox="0 0 24 24" fill="none" aria-label="LinkedIn">
            <rect width="24" height="24" rx="4" fill="#0A66C2"/>
            <path d="M6.94 5.5A1.44 1.44 0 1 1 5.5 6.94 1.44 1.44 0 0 1 6.94 5.5ZM5.5 9.5H8.38V18H5.5ZM10.5 9.5h2.76v1.17h.04A3 3 0 0 1 16 9.25c2.9 0 3.44 1.9 3.44 4.37V18H16.6v-3.78c0-1 0-2.3-1.4-2.3s-1.62 1.08-1.62 2.23V18H10.5Z" fill="white"/>
          </svg>

          <div class="contact__li-profile">
            <div class="contact__li-avatar" aria-hidden="true">
              <img
                src="/profile.jpg"
                alt=""
                width="52"
                height="52"
                loading="lazy"
                onerror="this.style.visibility='hidden'"
              />
              <span class="contact__li-initials">LJB</span>
            </div>
            <div>
              <p class="contact__li-name">Lucas Jimenez Boulot</p>
              <p class="contact__li-role">Développeur Full-Stack · Montpellier</p>
            </div>
          </div>
        </div>

        <div class="contact__li-body">
          <p class="contact__li-pitch">
            Je réponds à toutes les demandes sérieuses — projet web, refonte, question technique,
            ou si vous souhaitez simplement échanger sur un sujet.
          </p>

          <ul class="contact__li-reasons" aria-label="Raisons de me contacter">
            <li>
              <span class="contact__li-check" aria-hidden="true">✓</span>
              Vous avez un projet web à développer ou à refondre
            </li>
            <li>
              <span class="contact__li-check" aria-hidden="true">✓</span>
              Vous cherchez un dev pour un projet interne ou une mission
            </li>
            <li>
              <span class="contact__li-check" aria-hidden="true">✓</span>
              Vous avez une question technique sur Drupal, PHP ou React
            </li>
          </ul>
        </div>

        <div class="contact__li-footer">
          <a
            href="https://fr.linkedin.com/in/%F0%9F%92%BB-lucas-jimenez-boulot-35629919b"
            class="btn contact__li-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="M'envoyer un message sur LinkedIn (ouvre dans un nouvel onglet)"
          >
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 2H4a2 2 0 0 0-2 2v16l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2Z"/>
            </svg>
            Envoyer un message sur LinkedIn
          </a>
          <p class="contact__li-delay">
            <span aria-hidden="true">⏱</span> Répond en général sous 48&nbsp;h
          </p>
        </div>
      </div>

    </div>

    {/* ── Types de projets ── */}
    <div class="contact__types reveal" aria-label="Types de projets">
      <p class="contact__types-label">Je peux vous aider sur&nbsp;:</p>
      <ul class="contact__types-list">
        {projectTypes.map(p => (
          <li class="contact__type-chip">
            <span aria-hidden="true">{p.icon}</span>
            {p.label}
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  .contact__header {
    max-width: 620px;
    margin-bottom: var(--space-10);
  }

  .contact__header strong {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }

  /* ── Layout principal ── */
  .contact__main {
    margin-bottom: var(--space-10);
  }

  /* ══ Card LinkedIn ══ */
  .contact__li-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-8);
    border-color: rgba(10, 102, 194, 0.3);
    position: relative;
    overflow: hidden;
  }

  .contact__li-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #0A66C2, transparent);
  }

  .contact__li-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact__li-logo {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .contact__li-profile {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .contact__li-avatar {
    position: relative;
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    overflow: hidden;
    background: var(--color-surface-2);
    border: 2px solid var(--color-border);
  }

  .contact__li-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 1;
  }

  .contact__li-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-2);
    z-index: 0;
  }

  .contact__li-name {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: 1.2;
  }

  .contact__li-role {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: 1.3;
    margin-top: 2px;
  }

  /* Body */
  .contact__li-pitch {
    font-size: var(--text-base);
    color: #c0c0c0;
    line-height: var(--leading-relaxed);
  }

  .contact__li-reasons {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: rgba(10, 102, 194, 0.05);
    border: 1px solid rgba(10, 102, 194, 0.15);
    border-radius: var(--radius-md);
  }

  .contact__li-reasons li {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: #c0c0c0;
    line-height: var(--leading-normal);
    align-items: flex-start;
  }

  .contact__li-check {
    color: #0A66C2;
    font-weight: var(--font-weight-bold);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Footer card */
  .contact__li-footer {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .contact__li-cta {
    background: #0A66C2;
    color: #fff;
    border: none;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .contact__li-cta:hover {
    background: #0958a8;
    color: #fff;
  }

  .contact__li-delay {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-3);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ── Types de projets ── */
  .contact__types {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact__types-label {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .contact__types-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .contact__type-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: #c0c0c0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: border-color var(--transition-fast), color var(--transition-fast);
    cursor: default;
  }

  .contact__type-chip:hover {
    border-color: var(--color-border-accent);
    color: var(--color-text);
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .contact__li-card { padding: var(--space-6); }
    .contact__li-footer { flex-direction: column; align-items: flex-start; }
  }
</style>
