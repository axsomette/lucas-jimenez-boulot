{
  "name": "mon-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:github": "base='/MonPortfolio' astro build",
    "build:server": "OUTPUT_MODE=server astro build",
    "build:hybrid": "OUTPUT_MODE=hybrid astro build",
    "preview": "astro preview",
    "start": "node dist/server/entry.mjs",
    "sync": "astro sync",
    "lint": "eslint . --ext .ts,.tsx,.astro && tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/node": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "motion": "^11.0.0",
    "three": "^0.170.0",
    "@types/three": "^0.170.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
